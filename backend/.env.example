PORT=3000

# Optional: restrict frontend origins
# FRONTEND_ORIGINS=https://online-store-three-xi.vercel.app,https://vendor-store-beta.vercel.app,https://customer-store.vercel.app

# Laragon / MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=sister_store

# Optional Cloudinary image storage
# If set, uploaded logos and product images will be stored on Cloudinary.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=sister-store
CLOUDINARY_SECURE_URL=true

# Change this for production
JWT_SECRET=change-this-secret
